<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0F"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🚗 SpeedMonitor"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:fontFamily="sans-serif-light" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Control de velocidad en tiempo real"
            android:textColor="#888888"
            android:textSize="13sp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="32dp" />

        <!-- Speed Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_background"
            android:padding="24dp"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VELOCIDAD ACTUAL"
                android:textColor="#888888"
                android:textSize="11sp"
                android:letterSpacing="0.15" />

            <TextView
                android:id="@+id/tvCurrentSpeed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="— km/h"
                android:textColor="#00E676"
                android:textSize="48sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp" />

        </LinearLayout>

        <!-- Status Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_background"
            android:padding="16dp"
            android:orientation="vertical"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ESTADO"
                android:textColor="#888888"
                android:textSize="11sp"
                android:letterSpacing="0.15"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Listo para iniciar"
                android:textColor="#CCCCCC"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- Speed Limit Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONFIGURAR LÍMITE DE VELOCIDAD"
                android:textColor="#888888"
                android:textSize="11sp"
                android:letterSpacing="0.15"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/tvSpeedLimit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Límite: 80 km/h"
                android:textColor="#FF8C00"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <SeekBar
                android:id="@+id/sbSpeedLimit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="200"
                android:progress="80"
                android:thumbTint="#FF8C00"
                android:progressTint="#FF8C00"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Rango: 20 — 200 km/h"
                android:textColor="#666666"
                android:textSize="12sp"
                android:gravity="center"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/btnSetLimit"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Guardar Límite"
                android:textColor="#000000"
                android:backgroundTint="#FF8C00"
                android:textStyle="bold"
                android:textSize="14sp"
                android:letterSpacing="0.05" />

        </LinearLayout>

        <!-- Control Buttons -->
        <Button
            android:id="@+id/btnStartService"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="▶  Iniciar Monitoreo"
            android:textColor="#000000"
            android:backgroundTint="#00E676"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnStopService"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="⏹  Detener Monitoreo"
            android:textColor="#FFFFFF"
            android:backgroundTint="#333333"
            android:textStyle="bold"
            android:textSize="16sp"
            android:enabled="false"
            android:layout_marginBottom="24dp" />

        <!-- Info note -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💡 Una vez activo, puedes usar otras apps. La miniventana flotante mostrará tu velocidad y sonará un doble bip si superas el límite."
            android:textColor="#555555"
            android:textSize="12sp"
            android:textAlignment="center"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginBottom="32dp" />

    </LinearLayout>

</ScrollView>
